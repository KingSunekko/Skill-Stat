<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top stroke color -->
    <item>
        <shape>
            <solid android:color="#2A2A40" />
        </shape>
    </item>
    <!-- Background color with top offset to create the stroke effect -->
    <item android:top="1.5dp">
        <shape>
            <solid android:color="#121223" />
        </shape>
    </item>
</layer-list>