<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Shadow -->
    <item>
        <shape>
            <solid android:color="#4A1414" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Main Body -->
    <item android:bottom="4dp">
        <shape>
            <solid android:color="#1F1F3D" />
            <stroke android:width="1.5dp" android:color="#FF4B4B" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>