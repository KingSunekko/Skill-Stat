<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Shadow/Edge (smaller) -->
    <item>
        <shape>
            <solid android:color="#1488CC" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Main Body (pushed down) -->
    <item android:bottom="1dp" android:top="3dp">
        <shape>
            <solid android:color="#21B1FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>