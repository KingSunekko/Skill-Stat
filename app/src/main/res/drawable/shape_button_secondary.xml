<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#000000" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:bottom="1dp" android:top="3dp">
                <shape>
                    <solid android:color="#1A1A2E" />
                    <stroke android:width="1.5dp" android:color="#353550" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#000000" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:bottom="4dp">
                <shape>
                    <solid android:color="#121223" />
                    <stroke android:width="1.5dp" android:color="#2A2A40" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>