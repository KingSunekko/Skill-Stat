<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/rl_achievements_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btn_back_achievements"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/shape_skill_card"
            android:backgroundTint="#2D2D44"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="←"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="@font/nunito_bold" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/btn_back_achievements"
            android:fontFamily="@font/nunito_extrabold"
            android:text="Achievements 🏆"
            android:textColor="@color/white"
            android:textSize="22sp" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rl_achievements_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="50dp">

            <!-- Summary Stats -->
            <LinearLayout
                android:id="@+id/card_achievements_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏅" android:textSize="18sp"/>
                    <TextView
                        android:id="@+id/tv_stats_earned_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0/14"
                        android:textColor="@color/white"
                        android:fontFamily="@font/nunito_extrabold"
                        android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Earned" android:textColor="@color/splash_text_secondary" android:textSize="10sp"/>
                </LinearLayout>

                <View android:layout_width="12dp" android:layout_height="1dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="18sp"/>
                    <TextView
                        android:id="@+id/tv_stats_badges_xp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 XP"
                        android:textColor="@color/white"
                        android:fontFamily="@font/nunito_extrabold"
                        android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="From Badges" android:textColor="@color/splash_text_secondary" android:textSize="10sp"/>
                </LinearLayout>

                <View android:layout_width="12dp" android:layout_height="1dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="18sp"/>
                    <TextView
                        android:id="@+id/tv_stats_remaining_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="14"
                        android:textColor="@color/white"
                        android:fontFamily="@font/nunito_extrabold"
                        android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Remaining" android:textColor="@color/splash_text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Earned Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_extrabold"
                android:text="✅ EARNED"
                android:textColor="@color/splash_text_secondary"
                android:textSize="14sp"
                android:letterSpacing="0.05"/>

            <LinearLayout
                android:id="@+id/ll_earned_badges_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">
                <!-- Will be populated via addBadgeItem -->
            </LinearLayout>

            <!-- Locked Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_extrabold"
                android:text="🔒 LOCKED"
                android:textColor="@color/splash_text_secondary"
                android:textSize="14sp"
                android:letterSpacing="0.05"/>

            <LinearLayout
                android:id="@+id/ll_locked_badges_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">
                <!-- Will be populated via addBadgeItem -->
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>