<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_chat_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1E">

    <!-- Header Container -->
    <LinearLayout
        android:id="@+id/ll_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:orientation="vertical"
        android:paddingTop="45dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Status Bar Spacer (Dynamic height) -->
        <View
            android:id="@+id/v_status_spacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingHorizontal="16dp">

            <FrameLayout
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:background="@drawable/shape_input_field"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/white" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/fl_avatar_container"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:layout_toEndOf="@id/btn_back">
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_avatar_bg"
                    android:backgroundTint="#3D3D5C"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/prof1" />
                <View
                    android:id="@+id/v_online_indicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/shape_notification_green" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/ll_header_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_quest_header"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_btn_nudge_practice"
                    android:backgroundTint="#2D2D44"
                    android:fontFamily="@font/nunito_extrabold"
                    android:paddingHorizontal="12dp"
                    android:text="🤝 Quest"
                    android:textAllCaps="false"
                    android:textColor="#00BCD4"
                    android:textSize="11sp" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_duel_header"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/shape_btn_nudge_practice"
                    android:backgroundTint="#2D2D44"
                    android:fontFamily="@font/nunito_extrabold"
                    android:paddingHorizontal="12dp"
                    android:text="⚔ Duel"
                    android:textAllCaps="false"
                    android:textColor="@color/splash_green"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_toEndOf="@id/fl_avatar_container"
                android:layout_toStartOf="@id/ll_header_actions"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Alex"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_semibold"
                    android:text="• Online"
                    android:textColor="@color/splash_green"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

    <!-- Joint Quest Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_quest_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:cardBackgroundColor="#252545"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="#3D3D5C"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/ll_header_container"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tv_quest_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="🤝 JOINT QUEST ACTIVE"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:letterSpacing="0.05" />
                <TextView
                    android:id="@+id/tv_quest_days_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/shape_pill_dark_3d"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:fontFamily="@font/nunito_bold"
                    android:text="-- days"
                    android:textColor="#BBBBCC"
                    android:textSize="10sp" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_quest_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/nunito_extrabold"
                android:text="0 / 0 min completed"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_quest_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:indicatorColor="#00BCD4"
                app:trackColor="#1A1A2E"
                app:trackCornerRadius="6dp"
                app:trackThickness="12dp"
                android:progress="0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_my_contribution"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/nunito_bold"
                    android:text="You: 0m"
                    android:textColor="#888899"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tv_partner_contribution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Partner: 0m"
                    android:textColor="#888899"
                    android:textSize="11sp"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_controls"
        app:layout_constraintTop_toBottomOf="@id/card_quest_progress" />

    <!-- Confetti Layer -->
    <FrameLayout
        android:id="@+id/confetti_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="20dp"
        android:clickable="false"
        android:focusable="false" />

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/ll_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F0F1E"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">
                <TextView
                    android:id="@+id/qr_keep_grinding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/shape_input_field"
                    android:fontFamily="@font/nunito_bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:text="Keep grinding! 💪"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/qr_lets_duel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/shape_input_field"
                    android:fontFamily="@font/nunito_bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:text="Let's duel! 🔥"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/qr_go_practice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_input_field"
                    android:fontFamily="@font/nunito_bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:text="Go practice! 👋"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">
            <ImageButton
                android:id="@+id/btn_attach"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shape_input_field"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#888899" />
            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/shape_input_field"
                android:fontFamily="@font/nunito_semibold"
                android:hint="Message..."
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:textColor="@color/white"
                android:textColorHint="#888899"
                android:textSize="15sp" />
            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/shape_btn_green_3d"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
