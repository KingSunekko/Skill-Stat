<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/splash_bg_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_extrabold"
        android:text="Start Joint Quest 🤝"
        android:textColor="@color/white"
        android:textSize="20sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/nunito_semibold"
        android:text="Work together to master a skill!"
        android:textColor="#8E8E93"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Target Practice (Minutes):"
        android:textColor="@color/white"
        android:fontFamily="@font/nunito_bold" />

    <EditText
        android:id="@+id/et_quest_minutes"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/shape_input_field"
        android:hint="e.g. 300"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textColor="@color/white"
        android:textColorHint="#4E4E61" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Duration (Days):"
        android:textColor="@color/white"
        android:fontFamily="@font/nunito_bold" />

    <EditText
        android:id="@+id/et_quest_days"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/shape_input_field"
        android:hint="e.g. 7"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textColor="@color/white"
        android:textColorHint="#4E4E61" />

</LinearLayout>
