<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/shape_input_field"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:layout_gravity="center"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Skill ✨"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/ll_header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- Skill Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SKILL NAME"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_bold"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.1"/>

            <EditText
                android:id="@+id/et_skill_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shape_input_field"
                android:hint="e.g. Violin, Photoshop..."
                android:textColorHint="#55FFFFFF"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/nunito_semibold"
                android:inputType="textCapWords"/>

            <!-- Popular Skills -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POPULAR SKILLS"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_bold"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.1"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_popular_skills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="4dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Python 🐍"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spanish 🇪🇸"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Piano 🎹"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drawing 🎨"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cooking 🍳"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Math 📐"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Design 🎨"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chess ♟️"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Photography 📷"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>

                <com.google.android.material.chip.Chip
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="French 🇫🇷"
                    android:textColor="@color/skill_chip_text_selector"
                    android:checkable="true"
                    app:chipBackgroundColor="#1C1C35"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="16dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="13sp"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Starting Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STARTING LEVEL"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_bold"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.1"/>

            <!-- Beginner -->
            <LinearLayout
                android:id="@+id/ll_beginner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱"
                    android:textSize="24sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beginner"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/nunito_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Just getting started"
                        android:textColor="#8E8E93"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_beginner_check"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="#58CC02"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Intermediate -->
            <LinearLayout
                android:id="@+id/ll_intermediate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="24sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intermediate"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/nunito_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Building momentum"
                        android:textColor="#8E8E93"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_intermediate_check"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="#58CC02"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Advanced -->
            <LinearLayout
                android:id="@+id/ll_advanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="24sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Advanced"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/nunito_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Refining mastery"
                        android:textColor="#8E8E93"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/iv_advanced_check"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="#58CC02"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Decay Timer -->
            <TextView
                android:id="@+id/tv_decay_timer_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DECAY TIMER — 1 DAYS"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_bold"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:padding="16dp"
                android:orientation="vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_decay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1.0"
                    android:valueTo="14.0"
                    android:stepSize="1.0"
                    android:value="1.0"
                    app:labelBehavior="gone"
                    app:trackHeight="8dp"
                    app:thumbRadius="10dp" />

                <LinearLayout
                    android:id="@+id/ll_decay_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/shape_input_field"
                    android:padding="12dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_decay_status_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛑"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/tv_decay_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="At Risk"
                        android:textColor="#FF4B4B"
                        android:textSize="14sp"
                        android:fontFamily="@font/nunito_bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Buttons -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_skill"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/shape_btn_login_selector"
                android:text="✓  ADD SKILL"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/nunito_bold"
                android:textAllCaps="true"
                android:enabled="false"
                android:alpha="0.5"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_cancel"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:text="CANCEL"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/nunito_bold"
                android:textAllCaps="true"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>