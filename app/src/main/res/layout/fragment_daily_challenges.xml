<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <LinearLayout
            android:id="@+id/ll_challenges_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="50dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/shape_skill_card"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/nunito_extrabold"
                android:text="Daily Challenges ⚡"
                android:textColor="@color/white"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- Progress Card -->
        <LinearLayout
            android:id="@+id/card_challenges_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/shape_skill_card"
            android:backgroundTint="#2D2D44"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/ll_challenges_header">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Today's Progress"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_challenges_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="0/5"
                    android:textColor="@color/splash_green"
                    android:textSize="18sp" />
            </RelativeLayout>

            <!-- Custom Progress Bar for consistency -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="16dp">
                <View
                    android:id="@+id/v_challenges_progress_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_progress_bg" />
                <View
                    android:id="@+id/v_challenges_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_progress_fill_green" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_challenges_xp_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/nunito_semibold"
                android:text="⭐ 0 XP earned today from challenges"
                android:textColor="@color/splash_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Streak Freeze Info -->
        <LinearLayout
            android:id="@+id/ll_streak_freeze"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/shape_skill_card"
            android:backgroundTint="#1A2D44"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/card_challenges_summary">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🧊"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Streak Freeze Active"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_freeze_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:text="You have 0 freezes left. Complete challenges to earn more!"
                    android:textColor="#8E8E93"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Challenges List -->
        <LinearLayout
            android:id="@+id/ll_challenges_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/ll_streak_freeze">
            <!-- Dynamically populated -->
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
