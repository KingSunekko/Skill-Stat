<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark">

    <!-- Title Header -->
    <LinearLayout
        android:id="@+id/ll_edit_skill_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btn_back_skill"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/shape_edit_btn_selector"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Back"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_edit_skill_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/nunito_bold"
            android:text="Edit Skill ✏️"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_edit_skill"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/ll_skill_actions"
        app:layout_constraintTop_toBottomOf="@id/ll_edit_skill_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="0.05"
                android:text="SKILL NAME"
                android:textColor="@color/splash_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_skill_name_edit"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/shape_input_selector"
                android:fontFamily="@font/nunito_semibold"
                android:hint="Skill Name"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textColorHint="#4E4E61"
                android:textSize="16sp" />

            <!-- Daily Practice Time Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="0.1"
                android:text="DAILY PRACTICE TIME 🎯"
                android:textColor="#8E8E93"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:orientation="vertical"
                android:padding="16dp">

                <GridLayout
                    android:id="@+id/gl_goal_presets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="2">

                    <TextView
                        android:id="@+id/tv_preset_5"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:text="5 min"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold" />

                    <TextView
                        android:id="@+id/tv_preset_10"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:text="10 min"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold" />

                    <TextView
                        android:id="@+id/tv_preset_15"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:text="15 min"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold" />

                    <TextView
                        android:id="@+id/tv_preset_20"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:text="20 min"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold" />

                    <TextView
                        android:id="@+id/tv_preset_30"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:text="30 min"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold" />

                    <TextView
                        android:id="@+id/tv_preset_45"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:text="45 min"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold" />
                </GridLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Or type any amount:"
                    android:textColor="#8E8E93"
                    android:textSize="12sp"
                    android:fontFamily="@font/nunito_semibold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/btn_minus_goal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/shape_input_field"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="−"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/ll_custom_goal"
                        android:layout_width="100dp"
                        android:layout_height="64dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/shape_input_field"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_goal_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:fontFamily="@font/nunito_bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_marginTop="4dp"
                            android:text="min"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"
                            android:fontFamily="@font/nunito_bold" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btn_plus_goal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/shape_input_field"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="+"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/shape_input_field"
                    android:backgroundTint="#1A58CC02"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗓️"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Weekly total"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_weekly_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="70 min"
                        android:textColor="#58CC02"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="16sp" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_mastery_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="0.05"
                android:text="MASTERY — 82%"
                android:textColor="@color/splash_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Progress Bar (Non-interactive) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="4dp">

                <View
                    android:id="@+id/mastery_view_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_progress_bg" />

                <View
                    android:id="@+id/mastery_view_fill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_progress_fill_green"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.82" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tv_decay_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="0.05"
                android:text="DECAY TIMER — 1 DAYS"
                android:textColor="@color/splash_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_input_field"
                android:padding="16dp"
                android:orientation="vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_decay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1.0"
                    android:valueTo="14.0"
                    android:stepSize="1.0"
                    android:value="1.0"
                    app:labelBehavior="gone"
                    app:trackHeight="10dp"
                    app:thumbRadius="12dp"
                    app:tickVisible="true"
                    app:haloRadius="0dp"
                    app:thumbColor="@color/splash_green"
                    app:trackColorActive="@color/splash_green"
                    app:trackColorInactive="#33FFFFFF"/>

                <LinearLayout
                    android:id="@+id/ll_decay_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/shape_input_field"
                    android:padding="12dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_decay_status_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛑"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/tv_decay_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="At Risk"
                        android:textColor="#FF4B4B"
                        android:textSize="14sp"
                        android:fontFamily="@font/nunito_bold"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="0.05"
                android:text="DANGER ZONE"
                android:textColor="@color/splash_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_remove_skill"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_btn_danger"
                android:fontFamily="@font/nunito_bold"
                android:text="🗑️ REMOVE THIS SKILL"
                android:textColor="#FF4B4B"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/ll_skill_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_skill_save"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/shape_btn_login_selector"
            android:backgroundTint="@null"
            android:fontFamily="@font/nunito_bold"
            android:text="💾 SAVE CHANGES"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_skill_cancel"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_btn_social_selector"
            android:backgroundTint="@null"
            android:fontFamily="@font/nunito_bold"
            android:text="CANCEL"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>