<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Header -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="50dp"
            android:background="@drawable/shape_skill_card"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/nunito_bold"
            android:text="Skill Decay Heatmap 📅"
            android:textColor="@color/white"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="@id/btn_back" />

        <!-- Stats row -->
        <LinearLayout
            android:id="@+id/ll_stats_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/shape_skill_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp">
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/shape_progress_fill"
                    android:backgroundTint="#4CAF50" />
                <TextView
                    android:id="@+id/tv_active_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunito_bold"
                    android:text="0d"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Days"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/shape_skill_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/tv_best_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunito_bold"
                    android:text="0d"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best Streak"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/shape_skill_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="20sp" />
                <TextView
                    android:id="@+id/tv_tracked_weeks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunito_bold"
                    android:text="0wk"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sharpness"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Heatmap Grid Card -->
        <LinearLayout
            android:id="@+id/ll_heatmap_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/shape_skill_card"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/ll_stats_row">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="Retention History (Last 15 Weeks)"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <!-- Heatmap labels and grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <!-- Day Labels -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingTop="25dp"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="M" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="T" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="W" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="T" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="F" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="S" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                    <TextView android:layout_width="wrap_content" android:layout_height="22dp" android:text="S" android:textColor="@color/splash_text_secondary" android:textSize="9sp" android:gravity="center" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Week Labels -->
                        <LinearLayout
                            android:id="@+id/ll_week_labels"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <!-- Dynamically populated -->
                        </LinearLayout>

                        <GridLayout
                            android:id="@+id/gl_heatmap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:columnCount="15"
                            android:rowCount="7"
                            android:orientation="vertical">
                            <!-- Dynamically populated -->
                        </GridLayout>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="At Risk"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="10sp" />
                <View android:layout_width="12dp" android:layout_height="12dp" android:layout_marginHorizontal="4dp" android:background="#FF4B4B" />
                <View android:layout_width="12dp" android:layout_height="12dp" android:layout_marginHorizontal="2dp" android:background="#FFD43B" />
                <View android:layout_width="12dp" android:layout_height="12dp" android:layout_marginHorizontal="2dp" android:background="#4CAF50" />
                <View android:layout_width="12dp" android:layout_height="12dp" android:layout_marginHorizontal="2dp" android:background="#58CC02" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Fresh"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_monthly_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:text="MONTHLY DECAY BREAKDOWN"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_heatmap_card" />

        <LinearLayout
            android:id="@+id/ll_monthly_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_monthly_label">
            <!-- Dynamically populated -->
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
