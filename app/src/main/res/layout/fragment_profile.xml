<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nsv_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="120dp">

        <!-- Header Section -->
        <LinearLayout
            android:id="@+id/ll_profile_header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/cv_profile_avatar"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginTop="60dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_avatar_bg"
                    android:backgroundTint="@color/splash_green" />

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_avatar_bg"
                    android:backgroundTint="@color/splash_bg_dark" />

                <ImageView
                    android:id="@+id/iv_profile_avatar"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:scaleType="centerInside"
                    tools:src="@drawable/prof1" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_profile_rank_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_achievement_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="🥇 Gold Rank"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_extrabold" />

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_extrabold"
                android:text="KingSunekko"
                android:textColor="@color/white"
                android:textSize="28sp" />

            <!-- KEEP: THE FORGE RPG PROGRESS -->
            <TextView
                android:id="@+id/tv_forge_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_bold"
                android:text="Novice 🛠️"
                android:textColor="#FFD700"
                android:textSize="16sp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_forge_xp"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:indicatorColor="@color/splash_green"
                app:trackColor="#1AFFFFFF"
                app:trackCornerRadius="4dp"
                app:trackThickness="6dp"
                android:progress="10" />

            <TextView
                android:id="@+id/tv_profile_handle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/nunito_bold"
                android:text="user@gmail.com"
                android:textColor="@color/splash_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Stat Pills Row -->
        <LinearLayout
            android:id="@+id/ll_stat_pills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/ll_profile_header_container">

            <TextView
                android:id="@+id/tv_streak_days"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/shape_pill_streak"
                android:backgroundTint="#FF9F00"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🔥 1 streak"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Improved XP Pill -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/shape_pill_xp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="10sp"
                        android:alpha="0.7" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="18sp"
                        android:layout_marginTop="1dp"
                        android:layout_marginStart="4dp"
                        android:shadowColor="#40000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="1" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_total_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="3683 XP"
                    android:textColor="#5E4300"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_skills_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/shape_pill_skills"
                android:backgroundTint="#A061FF"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🧠 5 skills"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Overall Statistics -->
        <TextView
            android:id="@+id/tv_label_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="OVERALL STATISTICS 📊"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_stat_pills" />

        <LinearLayout
            android:id="@+id/ll_stats_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_skill_card"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_stats">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Best Streak"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_stat_best_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="0 days"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#35355A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Total Sessions"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_stat_total_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="141"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#35355A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Win Rate"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_stat_win_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="60.0%"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:id="@+id/ll_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/shape_skill_card"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/ll_stats_card">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Daily Goal"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_daily_goal_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="⏱️ 1 min"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#35355A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Skills Tracked"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_skills_tracked_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="5 📚"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#35355A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Bio"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_bio_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="tae"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Achievements -->
        <TextView
            android:id="@+id/tv_label_achievements"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="ACHIEVEMENTS 🏅"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_info_card" />

        <GridLayout
            android:id="@+id/gl_achievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:columnCount="3"
            app:layout_constraintTop_toBottomOf="@id/tv_label_achievements">
        </GridLayout>

        <!-- Settings Section -->
        <TextView
            android:id="@+id/tv_label_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="SETTINGS ⚙️"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gl_achievements" />

        <TextView
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_pill_dark_3d"
            android:fontFamily="@font/nunito_extrabold"
            android:gravity="center"
            android:text="✏️ EDIT PROFILE"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_label_settings" />

        <TextView
            android:id="@+id/btn_daily_goal"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_pill_dark_3d"
            android:fontFamily="@font/nunito_extrabold"
            android:gravity="center"
            android:text="⏱️ DAILY PRACTICE GOAL"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btn_edit_profile" />

        <!-- My Progress Section -->
        <TextView
            android:id="@+id/tv_label_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="MY PROGRESS 📈"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_daily_goal" />

        <GridLayout
            android:id="@+id/gl_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            app:layout_constraintTop_toBottomOf="@id/tv_label_progress">

            <TextView
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_pill_dark_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="📄 HISTORY"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_ghost_library"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_btn_ai_gradient_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="👻 GHOST RECORDS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_badges"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_pill_dark_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="🏆 BADGES"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_heatmap"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_pill_dark_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="🗓️ HEATMAP"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_weekly"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_pill_dark_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="📊 WEEKLY"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_sub_skills"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_pill_dark_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="⚒️ THE FORGE"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_categories"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/shape_pill_dark_3d"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="📂 CATEGORIES"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />
        </GridLayout>

        <!-- Toggle Options -->
        <LinearLayout
            android:id="@+id/ll_reminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/gl_progress">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_extrabold"
                android:text="🔔 Daily Reminder"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_daily_reminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:useMaterialThemeColors="false"
                app:thumbTint="@color/white"
                app:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <View
            android:id="@+id/div1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_reminders" />

        <LinearLayout
            android:id="@+id/ll_decay_alerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/div1">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_extrabold"
                android:text="⚠️ Decay Alerts"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_decay_alerts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:useMaterialThemeColors="false"
                app:thumbTint="@color/white"
                app:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <View
            android:id="@+id/div2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_decay_alerts" />

        <TextView
            android:id="@+id/btn_logout_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:text="🚪 Log Out"
            android:textColor="#FF4B4B"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/div2" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
