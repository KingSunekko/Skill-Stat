<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="120dp">

        <!-- Header Section -->
        <FrameLayout
            android:id="@+id/fl_avatar_container"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="60dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Glowing Ring -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_avatar_bg"
                android:backgroundTint="@color/splash_green" />

            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:background="@drawable/shape_avatar_bg"
                android:backgroundTint="@color/splash_bg_dark" />

            <TextView
                android:id="@+id/tv_profile_avatar_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🧙‍♂️"
                android:textSize="55sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/nunito_extrabold"
            android:text="SkillStatUser"
            android:textColor="@color/white"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/fl_avatar_container" />

        <TextView
            android:id="@+id/tv_profile_handle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito_bold"
            android:text="ID: user_000127 - Level 8 ⚡"
            android:textColor="@color/splash_text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_name" />

        <!-- Stat Pills Row -->
        <LinearLayout
            android:id="@+id/ll_stat_pills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_handle">

            <TextView
                android:id="@+id/tv_streak_days"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/shape_pill_streak"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🔥 6 streak"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_total_points"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/shape_pill_xp"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="⭐ 3,135 XP"
                android:textColor="#5E4300"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_skills_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/shape_pill_skills"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🧠 3 skills"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:id="@+id/ll_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/shape_skill_card"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/ll_stat_pills">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Daily Goal"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_daily_goal_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="⏱️ 20 min"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#35355A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Skills Tracked"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_skills_tracked_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="3 📚"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#35355A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Bio"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_bio_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_extrabold"
                    android:text="Lifelong learner."
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Achievements -->
        <TextView
            android:id="@+id/tv_label_achievements"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="ACHIEVEMENTS 🏅"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_info_card" />

        <GridLayout
            android:id="@+id/gl_achievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:columnCount="3"
            app:layout_constraintTop_toBottomOf="@id/tv_label_achievements">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🔥 7-Day Streak"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="⭐ 1000 XP"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🧠 3 Skills"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="📊 First Practice"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🔒 Top 10"
                android:textColor="@color/splash_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🔒 Mastered"
                android:textColor="@color/splash_text_secondary"
                android:textSize="10sp" />
        </GridLayout>

        <!-- Settings Section -->
        <TextView
            android:id="@+id/tv_label_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="SETTINGS ⚙️"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gl_achievements" />

        <TextView
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_skill_card"
            android:fontFamily="@font/nunito_extrabold"
            android:gravity="center"
            android:text="✏️ EDIT PROFILE"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_label_settings" />

        <TextView
            android:id="@+id/btn_daily_goal"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_skill_card"
            android:fontFamily="@font/nunito_extrabold"
            android:gravity="center"
            android:text="⏱️ DAILY PRACTICE GOAL"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btn_edit_profile" />

        <!-- My Progress Section -->
        <TextView
            android:id="@+id/tv_label_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:letterSpacing="0.1"
            android:text="MY PROGRESS 📈"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_daily_goal" />

        <GridLayout
            android:id="@+id/gl_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            app:layout_constraintTop_toBottomOf="@id/tv_label_progress">

            <TextView
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="📄 HISTORY"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_badges"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="🏆 BADGES"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_heatmap"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="🗓️ HEATMAP"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_weekly"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="📊 WEEKLY"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_sub_skills"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="🔬 SUB-SKILLS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_categories"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_extrabold"
                android:gravity="center"
                android:text="📁 CATEGORIES"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />
        </GridLayout>

        <!-- Toggle Options -->
        <LinearLayout
            android:id="@+id/ll_reminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/gl_progress">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_extrabold"
                android:text="🔔 Daily Reminder"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:useMaterialThemeColors="false"
                app:thumbTint="@color/white"
                app:trackTint="@color/splash_green" />
        </LinearLayout>

        <View
            android:id="@+id/div1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_reminders" />

        <LinearLayout
            android:id="@+id/ll_decay_alerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/div1">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_extrabold"
                android:text="⚠️ Decay Alerts"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:useMaterialThemeColors="false"
                app:thumbTint="@color/white"
                app:trackTint="@color/splash_green" />
        </LinearLayout>

        <View
            android:id="@+id/div2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_decay_alerts" />

        <TextView
            android:id="@+id/btn_logout_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_extrabold"
            android:text="🚪 Log Out"
            android:textColor="#FF4B4B"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/div2" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>