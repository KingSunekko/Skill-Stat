<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp">

        <!-- Avatar Section -->
        <FrameLayout
            android:id="@+id/profile_avatar_container"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_logo_glow" />

            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:background="@drawable/shape_logo_circle" />

            <TextView
                android:id="@+id/tv_profile_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🧙‍♂️"
                android:textSize="50sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/nunito_bold"
            android:text="SkillStatUser"
            android:textColor="@color/splash_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profile_avatar_container" />

        <TextView
            android:id="@+id/tv_profile_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito_semibold"
            android:text="ID: user_000127 • Level 8 ⚡"
            android:textColor="@color/splash_text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_name" />

        <!-- Stat Pills -->
        <LinearLayout
            android:id="@+id/ll_stats_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_id">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/shape_pill_streak"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🔥 6 streak"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1.2"
                android:background="@drawable/shape_pill_xp"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="⭐ 3,135 XP"
                android:textColor="#5E4300"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/shape_pill_skills"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="🧠 3 skills"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:id="@+id/ll_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/shape_profile_card"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/ll_stats_row">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Daily Goal"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="⏰ 20 min"
                    android:textColor="@color/splash_text_primary"
                    android:textSize="14sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#35355A"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Skills Tracked"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="3 📚"
                    android:textColor="@color/splash_text_primary"
                    android:textSize="14sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#35355A"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Bio"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Lifelong learner."
                    android:textColor="@color/splash_text_primary"
                    android:textSize="14sp" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Achievements Section -->
        <TextView
            android:id="@+id/tv_achievements_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_bold"
            android:text="ACHIEVEMENTS 🏅"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_info_card" />

        <GridLayout
            android:id="@+id/gl_achievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:columnCount="3"
            app:layout_constraintTop_toBottomOf="@id/tv_achievements_title">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="🔥 7d Streak"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="⭐ 1000 XP"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="🧠 3 Skills"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_achievement_badge"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="📊 First Practice"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_profile_card"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="🔒 Top 10"
                android:textColor="@color/splash_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/shape_profile_card"
                android:fontFamily="@font/nunito_bold"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:text="🔒 Mastered"
                android:textColor="@color/splash_text_secondary"
                android:textSize="11sp" />
        </GridLayout>

        <!-- Settings Section -->
        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/nunito_bold"
            android:text="SETTINGS ⚙️"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gl_achievements" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_edit_btn_selector"
            android:fontFamily="@font/nunito_bold"
            android:text="✏️ EDIT PROFILE"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_settings_title" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_daily_goal_settings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_edit_btn_selector"
            android:fontFamily="@font/nunito_bold"
            android:text="⏰ DAILY PRACTICE GOAL"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/btn_edit_profile" />

        <LinearLayout
            android:id="@+id/ll_reminders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            app:layout_constraintTop_toBottomOf="@id/btn_daily_goal_settings">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_bold"
                android:text="🔔 Daily Reminder"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/white"
                app:trackTint="@color/splash_green" />
        </LinearLayout>

        <View
            android:id="@+id/divider_reminders"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_reminders" />

        <LinearLayout
            android:id="@+id/ll_decay_alerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            app:layout_constraintTop_toBottomOf="@id/divider_reminders">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_bold"
                android:text="⚠️ Decay Alerts"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/white"
                app:trackTint="@color/splash_green" />
        </LinearLayout>

        <View
            android:id="@+id/divider_decay"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_decay_alerts" />

        <TextView
            android:id="@+id/btn_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/nunito_bold"
            android:padding="8dp"
            android:text="🚪 Log Out"
            android:textColor="#FF4B4B"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider_decay" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>