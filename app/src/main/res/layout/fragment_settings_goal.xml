<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/ll_goal_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/shape_skill_card"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/nunito_bold"
            android:text="Daily Goal ⏰"
            android:textColor="@color/white"
            android:textSize="22sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btn_save_goal"
        app:layout_constraintTop_toBottomOf="@id/ll_goal_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Big Goal Card -->
            <LinearLayout
                android:id="@+id/cv_goal_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_goal_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:id="@+id/tv_display_goal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="20"
                    android:textColor="#58CC02"
                    android:textSize="72sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="minutes per day 🔥"
                    android:textColor="#58CC02"
                    android:textSize="18sp"
                    android:layout_marginTop="-8dp" />
            </LinearLayout>

            <!-- Quick Select -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_extrabold"
                android:letterSpacing="0.05"
                android:text="QUICK SELECT"
                android:textColor="@color/splash_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/gl_goal_presets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_goal_5"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold" />

                <TextView
                    android:id="@+id/btn_goal_10"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:text="10"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold" />

                <TextView
                    android:id="@+id/btn_goal_15"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:text="15"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold" />

                <TextView
                    android:id="@+id/btn_goal_20"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_goal_option_selected"
                    android:gravity="center"
                    android:text="20"
                    android:textColor="#58CC02"
                    android:fontFamily="@font/nunito_bold" />

                <TextView
                    android:id="@+id/btn_goal_30"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:text="30"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold" />

                <TextView
                    android:id="@+id/btn_goal_45"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_skill_card"
                    android:gravity="center"
                    android:text="45"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold" />
            </LinearLayout>

            <!-- Custom Minutes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_extrabold"
                android:letterSpacing="0.05"
                android:text="CUSTOM (MINUTES)"
                android:textColor="@color/splash_text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_custom_goal"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_skill_card"
                android:fontFamily="@font/nunito_bold"
                android:hint="e.g. 25"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:textColor="@color/white"
                android:textColorHint="@color/splash_text_secondary" />

            <!-- Power Tip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/shape_info_banner_gold"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="💡 Power Tip"
                    android:textColor="#FFD700"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:lineSpacingExtra="4dp"
                    android:text="Even 10 minutes daily beats 2 hours once a week! 🔥"
                    android:textColor="#BFBFBF"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_save_goal"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/shape_btn_green_3d"
        android:fontFamily="@font/nunito_bold"
        android:text="💾 SAVE GOAL"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>