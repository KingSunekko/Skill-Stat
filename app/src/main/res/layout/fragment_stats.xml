<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="50dp"
            android:paddingBottom="100dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Progress"
                    android:textColor="@color/white"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="📊"
                    android:textSize="24sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito_semibold"
                android:text="7-day skill growth tracking"
                android:textColor="@color/splash_text_secondary"
                android:textSize="14sp" />

            <!-- Skill Tabs (Custom 3D Designs) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:id="@+id/ll_stats_tabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="2dp">

                    <TextView
                        android:id="@+id/tab_java"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_skill_chip_selector"
                        android:text="Java 💻"
                        android:textColor="@color/skill_chip_text_selector"
                        android:fontFamily="@font/nunito_bold"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <View android:layout_width="12dp" android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tab_guitar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_skill_chip_selector"
                        android:text="Guitar 🎸"
                        android:textColor="@color/skill_chip_text_selector"
                        android:fontFamily="@font/nunito_bold"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <View android:layout_width="12dp" android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tab_public_speaking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_skill_chip_selector"
                        android:text="Public Speaking 🎤"
                        android:textColor="@color/skill_chip_text_selector"
                        android:fontFamily="@font/nunito_bold"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Main Chart Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/shape_skill_card"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_stats_skill_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_bold"
                            android:text="Java 💻"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="Last 7 days"
                            android:textColor="@color/splash_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_stats_percentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nunito_bold"
                        android:text="82%"
                        android:textColor="@color/splash_green"
                        android:textSize="32sp" />
                </RelativeLayout>

                <!-- Chart Visualization -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">

                    <!-- Growth Badge Floating Top Right -->
                    <TextView
                        android:id="@+id/tv_stats_growth_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/shape_reward_skill_pill"
                        android:fontFamily="@font/nunito_bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="+27% this week 📈"
                        android:textColor="@color/white"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:id="@+id/ll_bar_chart"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="20dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        <include layout="@layout/layout_stat_bar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    </LinearLayout>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="#33FFFFFF" />

                <!-- Summary Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_peak_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_bold"
                            android:text="82%"
                            android:textColor="@color/splash_green"
                            android:textSize="18sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☑ Peak"
                            android:textColor="@color/splash_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_low_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_bold"
                            android:text="55%"
                            android:textColor="#FF9800"
                            android:textSize="18sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📉 Low"
                            android:textColor="@color/splash_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_avg_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_bold"
                            android:text="70%"
                            android:textColor="#21B1FF"
                            android:textSize="18sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Avg"
                            android:textColor="@color/splash_text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Decay Status Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="0.05"
                android:text="DECAY STATUS"
                android:textColor="@color/splash_text_secondary"
                android:textSize="13sp" />

            <!-- Decay List -->
            <LinearLayout
                android:id="@+id/ll_decay_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <include layout="@layout/item_decay_status" />
                <View android:layout_width="match_parent" android:layout_height="12dp" />
                <include layout="@layout/item_decay_status" />
                <View android:layout_width="match_parent" android:layout_height="12dp" />
                <include layout="@layout/item_decay_status" />
            </LinearLayout>

            <!-- Ebbinghaus Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/shape_info_banner_gold"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="📖 Ebbinghaus Forgetting Curve"
                    android:textColor="#FFD700"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunito_semibold"
                    android:lineSpacingExtra="4dp"
                    android:text="Skills decay over time without practice. SkillStat uses the Ebbinghaus model to predict when each skill is at risk before forgetting sets in! 🧠"
                    android:textColor="#BFBFBF"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>