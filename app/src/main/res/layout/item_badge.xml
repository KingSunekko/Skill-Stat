<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_badge_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/shape_skill_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <FrameLayout
        android:id="@+id/fl_badge_icon_container"
        android:layout_width="55dp"
        android:layout_height="55dp">
        <View
            android:id="@+id/v_badge_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_avatar_bg"
            android:backgroundTint="#2D2D44" />
        <TextView
            android:id="@+id/tv_badge_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🌱"
            android:textSize="28sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_badge_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="First Step"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_badge_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_semibold"
            android:text="Complete your first practice session"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_badge_xp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/shape_reward_skill_pill"
        android:backgroundTint="#1D2A1D"
        android:fontFamily="@font/nunito_extrabold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="+50 XP"
        android:textColor="@color/splash_green"
        android:textSize="12sp" />

</LinearLayout>