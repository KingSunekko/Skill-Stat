<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/shape_skill_card"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:id="@+id/rl_category_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_category_icon_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_extrabold"
            android:text="💻 Tech"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_category_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_reward_skill_pill"
                android:backgroundTint="#35355A"
                android:fontFamily="@font/nunito_bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_category_expand_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="▼"
                android:textColor="@color/splash_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Expandable Section -->
    <LinearLayout
        android:id="@+id/ll_category_expandable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#35355A" />

        <!-- Skills Chip Container -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_category_skills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <!-- Sample Chips or dynamic addition -->
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tv_empty_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="No skills in this category yet."
            android:textColor="@color/splash_text_secondary"
            android:fontFamily="@font/nunito_semibold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_add_skill_category"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_btn_green_3d"
            android:fontFamily="@font/nunito_extrabold"
            android:gravity="center"
            android:text="+ ADD SKILL"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>