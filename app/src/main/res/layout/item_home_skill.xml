<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/shape_skill_card"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_skill_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="Java 💻"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/ll_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@drawable/shape_status_badge"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <View
                android:id="@+id/v_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/shape_star_dot"
                android:backgroundTint="#FF4B4B" />

            <TextView
                android:id="@+id/tv_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/nunito_bold"
                android:text="At Risk"
                android:textColor="#FF4B4B"
                android:textSize="11sp" />
        </LinearLayout>
    </RelativeLayout>

    <View
        android:id="@+id/v_progress_bg"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/shape_progress_bg" />

    <View
        android:id="@+id/v_progress_fill"
        android:layout_width="200dp"
        android:layout_height="10dp"
        android:layout_marginTop="-10dp"
        android:background="@drawable/shape_progress_fill" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/tv_skill_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_semibold"
            android:text="82% • Advanced"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_time_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/nunito_bold"
                android:text="1d left"
                android:textColor="@color/splash_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

</LinearLayout>