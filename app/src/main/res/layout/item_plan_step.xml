<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/shape_skill_card"
    android:backgroundTint="#1A1F35"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/shape_avatar_bg"
        android:backgroundTint="#2D324A">
        <TextView
            android:id="@+id/tv_step_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🔥"
            android:textSize="24sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_step_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="Warm up"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/tv_step_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_semibold"
            android:text="AI Task Description"
            android:textColor="#A0A0B0"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tv_step_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito_semibold"
            android:text="⏱ 5 min"
            android:textColor="#8E8E93"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_step_xp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_status_badge"
        android:backgroundTint="#2D321F"
        android:fontFamily="@font/nunito_extrabold"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="+15 XP"
        android:textColor="#58CC02"
        android:textSize="13sp" />

</LinearLayout>