<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/shape_skill_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="45dp"
        android:layout_height="45dp">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_avatar_bg"
            android:backgroundTint="#2D2D44" />
        <TextView
            android:id="@+id/tv_avatar_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="👤"
            android:textSize="24sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="Name"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_mutual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_semibold"
            android:text="@username"
            android:textColor="@color/splash_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_skill_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_semibold"
            android:text="Rank • Lv.1"
            android:textColor="@color/splash_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_btn_green_3d"
        android:fontFamily="@font/nunito_bold"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="+ Add"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>