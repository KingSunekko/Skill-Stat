<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:orientation="horizontal"
    android:background="@drawable/shape_bottom_nav_bg"
    android:gravity="center_vertical"
    android:paddingHorizontal="8dp"
    android:elevation="8dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/pillHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="22sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOME"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_extrabold" />
    </LinearLayout>

    <!-- Skills -->
    <LinearLayout
        android:id="@+id/navSkills"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/pillSkills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="22sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelSkills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKILLS"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_extrabold" />
    </LinearLayout>

    <!-- Friends -->
    <LinearLayout
        android:id="@+id/navFriends"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/pillFriends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥"
                android:textSize="22sp" />

            <!-- Badge -->
            <TextView
                android:id="@+id/tv_friends_badge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shape_status_at_risk"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:fontFamily="@font/nunito_bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelFriends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FRIENDS"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_extrabold" />
    </LinearLayout>

    <!-- Ranks -->
    <LinearLayout
        android:id="@+id/navRanks"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/pillRanks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="22sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelRanks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RANKS"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_extrabold" />
    </LinearLayout>

    <!-- Me -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/pillProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="22sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ME"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito_extrabold" />
    </LinearLayout>

</LinearLayout>