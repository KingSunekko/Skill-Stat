<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_empty_state"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:visibility="gone">

    <TextView
        android:id="@+id/tv_empty_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📭"
        android:textSize="64sp" />

    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/nunito_bold"
        android:text="Nothing here yet"
        android:textColor="@color/white"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tv_empty_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/nunito_semibold"
        android:gravity="center"
        android:text="Start by adding some friends or creating a new skill!"
        android:textColor="@color/splash_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/btn_empty_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/shape_btn_green_3d"
        android:fontFamily="@font/nunito_extrabold"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:text="FIND FRIENDS"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:visibility="gone" />
</LinearLayout>
