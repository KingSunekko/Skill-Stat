<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/shape_skill_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_duel_skill_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="Skill Name"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/v_duel_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="✓"
            android:textColor="@color/splash_green"
            android:textSize="18sp"
            android:fontFamily="@font/nunito_bold"
            android:visibility="gone" />
    </RelativeLayout>

    <View
        android:id="@+id/v_duel_progress_bg"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/shape_progress_bg" />

    <View
        android:id="@+id/v_duel_progress_fill"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginTop="-8dp"
        android:background="@drawable/shape_progress_fill" />

    <TextView
        android:id="@+id/tv_duel_skill_mastery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your mastery: 0%"
        android:textColor="@color/splash_text_secondary"
        android:textSize="11sp" />

</LinearLayout>